{
  "entities": {
    "Artwork": {
      "title": "Artwork",
      "description": "A generated AI artwork piece.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "prompt": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "style": { "type": "string" },
        "likedBy": { 
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["title", "imageUrl", "prompt", "creatorId", "createdAt"]
    },
    "CuratedPost": {
      "title": "CuratedPost",
      "description": "A post curated by the AI curator.",
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "curatorComment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["source", "content", "curatorComment", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "twitterTokens": {
          "type": "object",
          "properties": {
            "accessToken": { "type": "string" },
            "refreshToken": { "type": "string" }
          }
        }
      },
      "required": ["displayName"]
    }
  },
  "firestore": {
    "/artworks/{artworkId}": {
      "schema": "Artwork",
      "description": "Collection of generated artworks."
    },
    "/curations/{curationId}": {
      "schema": "CuratedPost",
      "description": "Collection of AI curated posts."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    }
  }
}
